<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Interaktives Abenteuer</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #121212;
      color: #e0e0e0;
      line-height: 1.6;
      padding: 20px;
      max-width: 800px;
      margin: 0 auto;
    }
    .screen {
      display: none;
    }
    .screen.active {
      display: block;
    }
    #stats {
      display: flex;
      justify-content: space-between;
      background-color: #1e1e1e;
      padding: 10px 15px;
      border-radius: 5px;
      margin-bottom: 20px;
      font-size: 14px;
    }
    .stat {
      text-align: center;
    }
    .stat-value {
      font-weight: bold;
      color: #4CAF50;
    }
    #story-text {
      background-color: #1e1e1e;
      padding: 15px;
      border-radius: 5px;
      margin-bottom: 20px;
      min-height: 100px;
    }
    .choice-button {
      display: block;
      width: 100%;
      padding: 12px;
      margin-bottom: 10px;
      background-color: #2d2d2d;
      color: white;
      border: none;
      border-radius: 5px;
      font-size: 16px;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .choice-button:hover {
      background-color: #3a3a3a;
    }
    #abbruch-button {
      background-color: #f44336;
      margin-top: 10px;
    }
    #abbruch-button:hover {
      background-color: #d32f2f;
    }
    .modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.8);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 100;
    }
    .modal.active {
      display: flex;
    }
    .modal-content {
      background-color: #1e1e1e;
      padding: 20px;
      border-radius: 10px;
      width: 90%;
      max-width: 500px;
      text-align: center;
    }
    .modal-button {
      display: block;
      width: 100%;
      padding: 10px;
      margin: 10px 0;
      background-color: #2d2d2d;
      color: white;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
    #save-name {
      width: 100%;
      padding: 10px;
      margin: 10px 0;
      background-color: #2d2d2d;
      color: white;
      border: 1px solid #444;
      border-radius: 5px;
    }
    #saved-games {
      list-style: none;
      padding: 0;
    }
    #saved-games li {
      margin: 10px 0;
    }
    #saved-games button {
      width: 100%;
      padding: 10px;
      background-color: #2d2d2d;
      border: none;
      border-radius: 5px;
      cursor: pointer;
    }
    h1, h2 {
      color: #BB86FC;
    }
    .parameter-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }
    .parameter-option {
      background-color: #1e1e1e;
      padding: 10px;
      border-radius: 5px;
      cursor: pointer;
    }
    .parameter-option:hover {
      background-color: #2d2d2d;
    }
    .parameter-option.selected {
      background-color: #BB86FC;
      color: white;
    }
    @media (max-width: 600px) {
      .parameter-grid {
        grid-template-columns: 1fr;
      }
      .choice-button {
        font-size: 14px;
      }
    }
  </style>
</head>
<body>
  <!-- Parameter-Auswahl -->
  <div id="parameter-screen" class="screen active">
    <h1>Dein Abenteuer beginnt!</h1>
    <p>Wähle deine Eigenschaften:</p>
    <div class="parameter-section">
      <h3>Alter</h3>
      <div class="parameter-grid" id="alter-options"></div>
    </div>
    <div class="parameter-section">
      <h3>Beruf</h3>
      <div class="parameter-grid" id="beruf-options"></div>
    </div>
    <div class="parameter-section">
      <h3>Genre</h3>
      <div class="parameter-grid" id="genre-options"></div>
    </div>
    <div class="parameter-section">
      <h3>Moralischer Fokus</h3>
      <div class="parameter-grid" id="fokus-options"></div>
    </div>
    <div class="parameter-section">
      <h3>Sprachstil</h3>
      <div class="parameter-grid" id="stil-options"></div>
    </div>
    <div class="parameter-section">
      <h3>Konsequenz-Level</h3>
      <div class="parameter-grid" id="konsequenz-options"></div>
    </div>
    <div class="parameter-section">
      <h3>Kernziel</h3>
      <div class="parameter-grid" id="ziel-options"></div>
    </div>
    <button id="start-game" class="choice-button">Spiel starten</button>
  </div>

  <!-- Spielscreen -->
  <div id="game-screen" class="screen">
    <div id="stats">
      <div class="stat">Mut: <span id="stat-mut" class="stat-value">0</span></div>
      <div class="stat">Logik: <span id="stat-logik" class="stat-value">0</span></div>
      <div class="stat">Empathie: <span id="stat-empathie" class="stat-value">0</span></div>
      <div class="stat">Gerechtigkeit: <span id="stat-gerechtigkeit" class="stat-value">0</span></div>
    </div>
    <div id="story-text"></div>
    <div id="choices"></div>
    <button id="abbruch-button" class="choice-button">Abbruch</button>
  </div>

  <!-- Abbruch-Menü -->
  <div id="abbruch-menu" class="modal">
    <div class="modal-content">
      <h2>Spiel unterbrechen</h2>
      <button id="weiterspielen" class="modal-button">Weiterspielen</button>
      <button id="speichern-beenden" class="modal-button">Speichern & Beenden</button>
    </div>
  </div>

  <!-- Speichern-Menü -->
  <div id="save-menu" class="modal">
    <div class="modal-content">
      <h2>Spiel speichern</h2>
      <input type="text" id="save-name" placeholder="Name (z. B. Uwe)">
      <div id="save-slots">
        <button onclick="saveGame(1)" class="modal-button">Slot 1</button>
        <button onclick="saveGame(2)" class="modal-button">Slot 2</button>
        <button onclick="saveGame(3)" class="modal-button">Slot 3</button>
        <button onclick="saveGame(4)" class="modal-button">Slot 4</button>
        <button onclick="saveGame(5)" class="modal-button">Slot 5</button>
      </div>
      <button id="cancel-save" class="modal-button">Abbrechen</button>
    </div>
  </div>

  <!-- Lade-Menü -->
  <div id="load-screen" class="screen">
    <h1>Spielstand laden</h1>
    <ul id="saved-games"></ul>
    <button id="new-game" class="choice-button">Neues Spiel</button>
  </div>

