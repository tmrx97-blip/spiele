  <script>
    // Spielzustand
    let gameState = {
      selectedParameters: {},
      currentScene: "start",
      stats: {
        mut: 0,
        logik: 0,
        empathie: 0,
        gerechtigkeit: 0
      },
      sceneVars: {},
      inventory: [],
      history: []
    };

    // DOM-Elemente
    const parameterScreen = document.getElementById('parameter-screen');
    const gameScreen = document.getElementById('game-screen');
    const loadScreen = document.getElementById('load-screen');
    const abbruchMenu = document.getElementById('abbruch-menu');
    const saveMenu = document.getElementById('save-menu');
    const storyText = document.getElementById('story-text');
    const choicesContainer = document.getElementById('choices');
    const savedGamesList = document.getElementById('saved-games');

    // Parameter und Szenen laden
    const parameters = JSON.parse(document.getElementById('parameters').textContent);
    const scenesData = JSON.parse(document.getElementById('scenes').textContent);

    // Parameter-Auswahl rendern
    function renderParameterOptions(category, containerId) {
      const container = document.getElementById(containerId);
      parameters[category].forEach(option => {
        const optionElement = document.createElement('div');
        optionElement.className = 'parameter-option';
        optionElement.textContent = `${option.label}: ${option.desc}`;
        optionElement.onclick = () => selectParameter(category, option.value);
        container.appendChild(optionElement);
      });
    }

    // Parameter auswählen
    function selectParameter(category, value) {
      // Entferne vorherige Auswahl
      document.querySelectorAll(`.parameter-option.selected`).forEach(el => {
        el.classList.remove('selected');
      });

      // Markiere neue Auswahl
      const options = document.querySelectorAll(`#${category}-options .parameter-option`);
      const selectedIndex = parameters[category].findIndex(opt => opt.value === value);
      options[selectedIndex].classList.add('selected');

      // Speichere Auswahl
      gameState.selectedParameters[category] = value;
    }

    // Spiel starten
    document.getElementById('start-game').onclick = () => {
      if (Object.keys(gameState.selectedParameters).length === 7) {
        parameterScreen.classList.remove('active');
        gameScreen.classList.add('active');
        renderScene(gameState.currentScene);
      } else {
        alert('Bitte wähle alle Parameter aus!');
      }
    };

    // Szene rendern
    function renderScene(sceneId) {
      gameState.currentScene = sceneId;
      const scene = scenesData.scenes[sceneId];

      // Stats aktualisieren
      updateStatsUI();

      // Szene vorbereiten
      if (scene.onEnter) {
        if (scene.onEnter.updateStats) {
          Object.entries(scene.onEnter.updateStats).forEach(([stat, value]) => {
            gameState.stats[stat] += value;
          });
        }
        if (scene.onEnter.setSceneVars) {
          gameState.sceneVars = { ...gameState.sceneVars, ...scene.onEnter.setSceneVars };
        }
        if (scene.onEnter.addInventory) {
          gameState.inventory.push(scene.onEnter.addInventory);
        }
      }

      // Text mit Platzhaltern ersetzen
      let text = scene.text;
      Object.entries(gameState.selectedParameters).forEach(([key, value]) => {
        const param = parameters[key].find(p => p.value === value);
        text = text.replace(new RegExp(`{${key.toUpperCase()}_LABEL}`, 'g'), param.label);
        text = text.replace(new RegExp(`{${key.toUpperCase()}_DESC}`, 'g'), param.desc);
      });

      // Genre-spezifische Platzhalter
      Object.entries(scenesData.sceneVars).forEach(([varName, varOptions]) => {
        if (typeof varOptions === 'object') {
          const selectedGenre = gameState.selectedParameters.genre;
          const selectedZiel = gameState.selectedParameters.ziel;
          const selectedFokus = gameState.selectedParameters.fokus;

          if (varOptions[selectedGenre]) {
            text = text.replace(new RegExp(`{${varName}}`, 'g'), varOptions[selectedGenre]);
          }
          if (varOptions[selectedZiel]) {
            text = text.replace(new RegExp(`{${varName}}`, 'g'), varOptions[selectedZiel]);
          }
          if (varOptions[selectedFokus]) {
            text = text.replace(new RegExp(`{${varName}}`, 'g'), varOptions[selectedFokus]);
          }
        }
      });

      storyText.textContent = text;
      choicesContainer.innerHTML = '';

      // Choices rendern
      scene.choices.forEach(choice => {
        if (!choice.condition || checkCondition(choice.condition)) {
          const button = document.createElement('button');
          button.className = 'choice-button';
          button.textContent = choice.text;
          button.onclick = () => {
            if (choice.nextScene) {
              renderScene(choice.nextScene);
            }
            if (choice.updateStats) {
              Object.entries(choice.updateStats).forEach(([stat, value]) => {
                gameState.stats[stat] += value;
              });
              updateStatsUI();
            }
          };
          choicesContainer.appendChild(button);
        }
      });
    }

    // Bedingung prüfen
    function checkCondition(condition) {
      return gameState.stats[condition.stat] >= condition.value;
    }

    // Stats-UI aktualisieren
    function updateStatsUI() {
      document.getElementById('stat-mut').textContent = gameState.stats.mut;
      document.getElementById('stat-logik').textContent = gameState.stats.logik;
      document.getElementById('stat-empathie').textContent = gameState.stats.empathie;
      document.getElementById('stat-gerechtigkeit').textContent = gameState.stats.gerechtigkeit;
    }

    // Abbruch-Button
    document.getElementById('abbruch-button').onclick = () => {
      abbruchMenu.classList.add('active');
    };

    // Abbruch-Menü
    document.getElementById('weiterspielen').onclick = () => {
      abbruchMenu.classList.remove('active');
    };

    document.getElementById('speichern-beenden').onclick = () => {
      abbruchMenu.classList.remove('active');
      saveMenu.classList.add('active');
    };

    document.getElementById('cancel-save').onclick = () => {
      saveMenu.classList.remove('active');
    };

    // Spiel speichern
    function saveGame(slot) {
      const name = document.getElementById('save-name').value || `Spielstand ${slot}`;
      const savedGames = JSON.parse(localStorage.getItem('savedGames')) || {};
      savedGames[slot] = {
        name: name,
        gameState: JSON.parse(JSON.stringify(gameState)),
        timestamp: new Date().toISOString()
      };
      localStorage.setItem('savedGames', JSON.stringify(savedGames));
      saveMenu.classList.remove('active');
      loadScreen.classList.add('active');
      gameScreen.classList.remove('active');
      renderSavedGames();
    }

    // Gespeicherte Spiele laden
    function renderSavedGames() {
      savedGamesList.innerHTML = '';
      const savedGames = JSON.parse(localStorage.getItem('savedGames')) || {};
      Object.entries(savedGames).forEach(([slot, game]) => {
        const li = document.createElement('li');
        li.innerHTML = `
          <button onclick="loadGame(${slot})">
            ${slot}: ${game.name} (${new Date(game.timestamp).toLocaleString()})
          </button>
        `;
        savedGamesList.appendChild(li);
      });
    }

    // Spiel laden
    window.loadGame = function(slot) {
      const savedGames = JSON.parse(localStorage.getItem('savedGames')) || {};
      if (savedGames[slot]) {
        gameState = savedGames[slot].gameState;
        loadScreen.classList.remove('active');
        gameScreen.classList.add('active');
        renderScene(gameState.currentScene);
      }
    };

    // Neues Spiel
    document.getElementById('new-game').onclick = () => {
      gameState = {
        selectedParameters: {},
        currentScene: "start",
        stats: { mut: 0, logik: 0, empathie: 0, gerechtigkeit: 0 },
        sceneVars: {},
        inventory: [],
        history: []
      };
      loadScreen.classList.remove('active');
      parameterScreen.classList.add('active');
    };

    // Initialisierung
    document.addEventListener('DOMContentLoaded', () => {
      // Parameter-Optionen rendern
      renderParameterOptions('alter', 'alter-options');
      renderParameterOptions('beruf', 'beruf-options');
      renderParameterOptions('genre', 'genre-options');
      renderParameterOptions('fokus', 'fokus-options');
      renderParameterOptions('stil', 'stil-options');
      renderParameterOptions('konsequenz', 'konsequenz-options');
      renderParameterOptions('ziel', 'ziel-options');

      // Gespeicherte Spiele anzeigen (falls vorhanden)
      renderSavedGames();
    });
  </script>
